# =============================================================================
# SUPABASE - Use the "API Keys" tab, NOT "Connection String" or "Session pooler"
# =============================================================================
# The Connection String / Session pooler is for direct Postgres connections
# (Prisma, Drizzle, etc.). This app uses the Supabase REST API - you need:
#
# 1. Open: Project Settings → API (or Connect → API Keys tab)
# 2. Copy "Project URL"  → NEXT_PUBLIC_SUPABASE_URL
# 3. Copy "anon" key OR "Publishable" key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Project URL looks like: https://xxxxxxxx.supabase.co
# Anon key looks like:    eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Publishable key:        sb_publishable_xxxxxxxx...
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Or use the new Publishable key (instead of anon):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Base URL for verification (REQUIRED for QR codes - must be absolute)
# Local:    http://localhost:3000
# Production: https://yourdomain.com (use your deployed URL for QR codes to work)
NEXT_PUBLIC_VERIFY_BASE_URL=http://localhost:3000
